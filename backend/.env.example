# =============================================================================
# CORS SETTINGS
# =============================================================================

# CORS Allowed Origins - Your Vercel frontend URL
# Example: CORS_ALLOWED_ORIGINS=https://your-app.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:3000

# CSRF Trusted Origins - Your Vercel frontend URL
# Example: CSRF_TRUSTED_ORIGINS=https://your-app.vercel.app
CSRF_TRUSTED_ORIGINS=http://localhost:3000

# =============================================================================
# API KEYS
# =============================================================================

# remove.bg API Key - Get from https://www.remove.bg/api
# Free tier: 50 API calls/month
REMOVE_BG_API_KEY=your-remove-bg-api-key

# =============================================================================
# LOCAL DEVELOPMENT (Optional)
# =============================================================================

# If not using DATABASE_URL, you can set individual database values:
# DB_NAME=skycodetoolsdb
# DB_USER=postgres
# DB_PASSWORD=your-password
# DB_HOST=localhost
# DB_PORT=5432

