# NEVER commit .env to version control!

# =============================================================================
# REQUIRED FOR PRODUCTION
# =============================================================================

# Django Secret Key - Generate a strong random key:
# Use: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=7-QG4szMWGokhugrMrloXLo1p1Dyqw3oz8E6RpPWGrN2RgwIU7-Q0LjgzWw7IDGPB8I

# Debug mode - Set to False for production
DEBUG=False

# Allowed Hosts - Comma-separated list of allowed domains
# Example: ALLOWED_HOSTS=example.com,www.example.com,backend.onrender.com
ALLOWED_HOSTS=localhost,127.0.0.1

# Database URL - PostgreSQL connection string from Render/Neon
# Format: postgres://username:password@hostname:port/database_name
DATABASE_URL=Connections
